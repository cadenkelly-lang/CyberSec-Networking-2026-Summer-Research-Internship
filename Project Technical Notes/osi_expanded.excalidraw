			"hasTextLink": false
		},
		{
			"id": "XZQrzQhh",
			"type": "text",
			"x": 600,
			"y": -1819.5330412718015,
			"width": 584.8995361328125,
			"height": 225,
			"angle": 0,
			"strokeColor": "#1971c2",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 2,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"index": "f0LYTLt",
			"roundness": null,
			"seed": 6417253,
			"version": 117,
			"versionNonce": 974526744,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1780695789603,
			"link": null,
			"locked": false,
			"text": "STEP-BY-STEP (same subnet):\n1  Host A checks: Is 192.168.1.20 in my /24? YES\n2  Host A checks ARP cache for 192.168.1.20 MAC\n3  If no ARP entry: broadcasts ARP Request\n   Who has 192.168.1.20? (Dst: FF:FF:FF:FF:FF:FF)\n4  Host B replies unicast with its MAC\n5  Host A updates ARP cache\n6  Host A builds frame: Dst=BB:BB:BB:22, Src=AA:AA:AA:11\n7  Switch forwards frame only to Host B port",
			"rawText": "STEP-BY-STEP (same subnet):\n1  Host A checks: Is 192.168.1.20 in my /24? YES\n2  Host A checks ARP cache for 192.168.1.20 MAC\n3  If no ARP entry: broadcasts ARP Request\n   Who has 192.168.1.20? (Dst: FF:FF:FF:FF:FF:FF)\n4  Host B replies unicast with its MAC\n5  Host A updates ARP cache\n6  Host A builds frame: Dst=BB:BB:BB:22, Src=AA:AA:AA:11\n7  Switch forwards frame only to Host B port",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "STEP-BY-STEP (same subnet):\n1  Host A checks: Is 192.168.1.20 in my /24? YES\n2  Host A checks ARP cache for 192.168.1.20 MAC\n3  If no ARP entry: broadcasts ARP Request\n   Who has 192.168.1.20? (Dst: FF:FF:FF:FF:FF:FF)\n4  Host B replies unicast with its MAC\n5  Host A updates ARP cache\n6  Host A builds frame: Dst=BB:BB:BB:22, Src=AA:AA:AA:11\n7  Switch forwards frame only to Host B port",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false
		},
