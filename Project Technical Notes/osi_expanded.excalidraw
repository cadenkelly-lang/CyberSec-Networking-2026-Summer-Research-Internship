			"text": "ICMP -- Internet Control Message Protocol",
			"rawText": "ICMP -- Internet Control Message Protocol",
			"fontSize": 24,
			"fontFamily": 5,
			"textAlign": "center",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "ICMP -- Internet Control Message Protocol",
			"autoResize": true,
