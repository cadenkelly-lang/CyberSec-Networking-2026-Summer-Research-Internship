			"boundElements": [],
			"updated": 1780694107349,
			"link": null,
			"locked": false,
			"text": "IEEE 802.3  -- Ethernet (wired)\nIEEE 802.11 -- Wi-Fi (wireless)\nRS-232  -- Serial (legacy)\nUSB  -- Universal Serial Bus\nHDMI  -- Multimedia interface\n\nCONNECTOR TYPES:\nRJ-45 -> Ethernet (Cat5e/6/6a)\nLC / SC / ST -> Fiber optic\nF-type -> Coaxial (cable TV)\nSFP / SFP+ -> Hot-swap transceiver",
			"rawText": "IEEE 802.3  -- Ethernet (wired)\nIEEE 802.11 -- Wi-Fi (wireless)\nRS-232  -- Serial (legacy)\nUSB  -- Universal Serial Bus\nHDMI  -- Multimedia interface\n\nCONNECTOR TYPES:\nRJ-45 -> Ethernet (Cat5e/6/6a)\nLC / SC / ST -> Fiber optic\nF-type -> Coaxial (cable TV)\nSFP / SFP+ -> Hot-swap transceiver",
			"fontSize": 13.047905674219843,
			"fontFamily": 5,
			"textAlign": "center",
			"verticalAlign": "middle",
			"containerId": "u3zyDwUF",
			"originalText": "IEEE 802.3  -- Ethernet (wired)\nIEEE 802.11 -- Wi-Fi (wireless)\nRS-232  -- Serial (legacy)\nUSB  -- Universal Serial Bus\nHDMI  -- Multimedia interface\n\nCONNECTOR TYPES:\nRJ-45 -> Ethernet (Cat5e/6/6a)\nLC / SC / ST -> Fiber optic\nF-type -> Coaxial (cable TV)\nSFP / SFP+ -> Hot-swap transceiver",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false
		},
