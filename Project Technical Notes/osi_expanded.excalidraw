		{
			"id": "l2_dom_b",
			"type": "text",
			"x": -2138.6742671842103,
			"y": -1066.5042467612407,
			"width": 554.0994873046875,
			"height": 200,
			"angle": 0,
			"strokeColor": "#1a1a1a",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 2,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"index": "f0LYTJX",
			"roundness": null,
			"seed": 7121923,
			"version": 541,
			"versionNonce": 2059229720,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1780694567466,
			"link": null,
			"locked": false,
			"text": "COLLISION DOMAIN: devices competing for same medium\n  Hub -> ALL ports share 1 collision domain\n  Switch -> each port has its OWN collision domain\nBROADCAST DOMAIN: receives FF:FF:FF:FF:FF:FF\nframes\n  Switch -> all ports in same VLAN = 1 broadcast domain\n  Router -> SEPARATES broadcast domains (each\ninterface = 1)",
			"rawText": "COLLISION DOMAIN: devices competing for same medium\n  Hub -> ALL ports share 1 collision domain\n  Switch -> each port has its OWN collision domain\nBROADCAST DOMAIN: receives FF:FF:FF:FF:FF:FF frames\n  Switch -> all ports in same VLAN = 1 broadcast domain\n  Router -> SEPARATES broadcast domains (each interface = 1)",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "center",
			"verticalAlign": "middle",
			"containerId": "OcJznkyV",
			"originalText": "COLLISION DOMAIN: devices competing for same medium\n  Hub -> ALL ports share 1 collision domain\n  Switch -> each port has its OWN collision domain\nBROADCAST DOMAIN: receives FF:FF:FF:FF:FF:FF frames\n  Switch -> all ports in same VLAN = 1 broadcast domain\n  Router -> SEPARATES broadcast domains (each interface = 1)",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false
		},
