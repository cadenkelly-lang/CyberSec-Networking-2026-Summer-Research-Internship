			"version": 742,
			"versionNonce": 13081639,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1780680470634,
			"locked": false,
			"text": "Physical equipment that transfers data, like\nswitches and cables. Data is converted from\nbinary. Devices must agree on how to\ndistinguish 1s from 0s so digital data can be\nconverted.",
			"rawText": "Physical equipment that transfers data, like switches and cables. Data is converted from binary. Devices must agree on how to distinguish 1s from 0s so digital data can be converted.",
			"fontSize": 28,
			"fontFamily": 5,
			"textAlign": "center",
			"verticalAlign": "middle",
			"containerId": "bx4t0SB2",
			"originalText": "Physical equipment that transfers data, like switches and cables. Data is converted from binary. Devices must agree on how to distinguish 1s from 0s so digital data can be converted.",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"link": null
		},
