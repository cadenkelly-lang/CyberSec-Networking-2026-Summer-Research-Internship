			"versionNonce": 1804241895,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1780682551939,
			"locked": false,
			"text": "Defines procedures for devices communicating,\nand provides framing and sequencing.\n\nMost switches are layer 2, but some are layer\nthree if they facilitate communication between\ntwo networks or VLANS (data needs to be\nrouted, which is a layer 3 task).",
			"rawText": "Defines procedures for devices communicating, and provides framing and sequencing.\n\nMost switches are layer 2, but some are layer three if they facilitate communication between two networks or VLANS (data needs to be routed, which is a layer 3 task).",
			"fontSize": 28,
			"fontFamily": 5,
			"textAlign": "center",
			"verticalAlign": "middle",
			"containerId": "B9QHrbW_5xqIvndVpUTc2",
			"originalText": "Defines procedures for devices communicating, and provides framing and sequencing.\n\nMost switches are layer 2, but some are layer three if they facilitate communication between two networks or VLANS (data needs to be routed, which is a layer 3 task).",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"link": null
		},
