			"boundElements": [],
			"updated": 1780696212223,
			"link": null,
			"locked": false,
			"text": "OSI All 7 Layers:\n\nAll  (Application)\nPeople  (Presentation)\nSeem  (Session)\nTo  (Transport)\nNeed  (Network)\nData  (Data Link)\nProcessing  (Physical)\n\n<- read bottom to top\n   for encapsulation ->",
			"rawText": "OSI All 7 Layers:\n\nAll  (Application)\nPeople  (Presentation)\nSeem  (Session)\nTo  (Transport)\nNeed  (Network)\nData  (Data Link)\nProcessing  (Physical)\n\n<- read bottom to top\n   for encapsulation ->",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "center",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "OSI All 7 Layers:\n\nAll  (Application)\nPeople  (Presentation)\nSeem  (Session)\nTo  (Transport)\nNeed  (Network)\nData  (Data Link)\nProcessing  (Physical)\n\n<- read bottom to top\n   for encapsulation ->",
