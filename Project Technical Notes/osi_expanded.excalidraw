			"seed": 4509120,
			"version": 178,
			"versionNonce": 1575431016,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1780695731218,
			"locked": false,
			"text": "TCP (Transmission Control Protocol):\n  Reliable, ordered, error-checked\n  Retransmits lost segments\n  HTTP, SMTP, SSH, FTP\n\nUDP (User Datagram Protocol):\n  Fast, no guarantee, no handshake\n  No retransmission -- fire and forget\n  DNS, DHCP, VoIP, video streaming",
			"rawText": "TCP (Transmission Control Protocol):\n  Reliable, ordered, error-checked\n  Retransmits lost segments\n  HTTP, SMTP, SSH, FTP\n\nUDP (User Datagram Protocol):\n  Fast, no guarantee, no handshake\n  No retransmission -- fire and forget\n  DNS, DHCP, VoIP, video streaming",
			"fontSize": 17.721860101227346,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "middle",
			"containerId": "K6RFRuOl",
			"originalText": "TCP (Transmission Control Protocol):\n  Reliable, ordered, error-checked\n  Retransmits lost segments\n  HTTP, SMTP, SSH, FTP\n\nUDP (User Datagram Protocol):\n  Fast, no guarantee, no handshake\n  No retransmission -- fire and forget\n  DNS, DHCP, VoIP, video streaming",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"link": null
		},
