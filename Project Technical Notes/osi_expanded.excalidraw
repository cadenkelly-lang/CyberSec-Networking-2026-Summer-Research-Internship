			"seed": 3558546,
			"version": 101,
			"versionNonce": 2116174440,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1780693999371,
			"link": null,
			"locked": false,
			"text": "REQUEST  (Broadcast to FF:FF:FF:FF:FF:FF):\nWho has 192.168.1.2?  Tell 192.168.1.1\n\nREPLY  (Unicast to requester):\n192.168.1.2 is at  AA:BB:CC:DD:EE:FF\n\nARP Cache: IP <-> MAC stored temporarily\nGratuitous ARP: announce own IP/MAC\nProxy ARP: router answers on behalf of host",
			"rawText": "REQUEST  (Broadcast to FF:FF:FF:FF:FF:FF):\nWho has 192.168.1.2?  Tell 192.168.1.1\n\nREPLY  (Unicast to requester):\n192.168.1.2 is at  AA:BB:CC:DD:EE:FF\n\nARP Cache: IP <-> MAC stored temporarily\nGratuitous ARP: announce own IP/MAC\nProxy ARP: router answers on behalf of host",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "REQUEST  (Broadcast to FF:FF:FF:FF:FF:FF):\nWho has 192.168.1.2?  Tell 192.168.1.1\n\nREPLY  (Unicast to requester):\n192.168.1.2 is at  AA:BB:CC:DD:EE:FF\n\nARP Cache: IP <-> MAC stored temporarily\nGratuitous ARP: announce own IP/MAC\nProxy ARP: router answers on behalf of host",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false
		},
