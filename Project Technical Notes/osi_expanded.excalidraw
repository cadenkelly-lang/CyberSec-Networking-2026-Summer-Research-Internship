			"boundElements": [],
			"updated": 1780694401834,
			"link": null,
			"locked": false,
			"text": "Builds/deconstructs frames\nCSMA/CD (Ethernet):\n  Detect collision -> backoff -> retry\nCSMA/CA (Wi-Fi):\n  Sense channel -> wait -> transmit\nFrame Check Sequence (CRC32):\n  Detects corrupted frames",
			"rawText": "Builds/deconstructs frames\nCSMA/CD (Ethernet):\n  Detect collision -> backoff -> retry\nCSMA/CA (Wi-Fi):\n  Sense channel -> wait -> transmit\nFrame Check Sequence (CRC32):\n  Detects corrupted frames",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Builds/deconstructs frames\nCSMA/CD (Ethernet):\n  Detect collision -> backoff -> retry\nCSMA/CA (Wi-Fi):\n  Sense channel -> wait -> transmit\nFrame Check Sequence (CRC32):\n  Detects corrupted frames",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false
		},
