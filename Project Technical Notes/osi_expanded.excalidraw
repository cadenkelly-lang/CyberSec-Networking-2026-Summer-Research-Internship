		},
		{
			"id": "evmwCxpX",
			"type": "text",
			"x": -1052.3847241460646,
			"y": -504.66024196933233,
			"width": 500.2846374511719,
			"height": 163.98693238343589,
			"angle": 0,
			"strokeColor": "#1a1a1a",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 2,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"index": "f0LYTJB",
			"roundness": null,
			"seed": 5761930,
			"version": 163,
			"versionNonce": 149504360,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1780694384177,
			"link": null,
			"locked": false,
			"text": "KNOWN UNICAST -> Forward only to matching port\nUNKNOWN UNICAST -> Flood to all ports (same VLAN)\nBROADCAST -> Flood to all ports (same VLAN)\nMULTICAST -> Flood (unless IGMP snooping)\n\nEach port = its own collision domain\nAll ports (same VLAN) = one broadcast domain",
			"rawText": "KNOWN UNICAST -> Forward only to matching port\nUNKNOWN UNICAST -> Flood to all ports (same VLAN)\nBROADCAST -> Flood to all ports (same VLAN)\nMULTICAST -> Flood (unless IGMP snooping)\n\nEach port = its own collision domain\nAll ports (same VLAN) = one broadcast domain",
			"fontSize": 18.7413637009641,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "KNOWN UNICAST -> Forward only to matching port\nUNKNOWN UNICAST -> Flood to all ports (same VLAN)\nBROADCAST -> Flood to all ports (same VLAN)\nMULTICAST -> Flood (unless IGMP snooping)\n\nEach port = its own collision domain\nAll ports (same VLAN) = one broadcast domain",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false
		},
