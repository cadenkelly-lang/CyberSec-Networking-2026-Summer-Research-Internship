			"boundElements": [],
			"updated": 1780682422533,
			"locked": false,
			"text": "Sub-layer 2 - Media Access\nControl (MAC): Puts data\nintro frames, then manages\nphysical transmission of it\nso data doesn't collide on\nsame channels of\ntransmission. \n",
			"rawText": "Sub-layer 2 - Media Access Control (MAC): Puts data intro frames, then manages physical transmission of it so data doesn't collide on same channels of transmission. \n",
			"fontSize": 28,
			"fontFamily": 5,
