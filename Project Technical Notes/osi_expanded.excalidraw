			"boundElements": [],
			"updated": 1780694227468,
			"link": null,
			"locked": false,
			"text": "FF:FF:FF:FF:FF:FF = Broadcast (all devices)\n01:xx:xx:xx:xx:xx = Multicast\n00:00:00:00:00:00 = Unknown/unset\nLSB of first byte=1 = Multicast bit",
			"rawText": "FF:FF:FF:FF:FF:FF = Broadcast (all devices)\n01:xx:xx:xx:xx:xx = Multicast\n00:00:00:00:00:00 = Unknown/unset\nLSB of first byte=1 = Multicast bit",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "center",
			"verticalAlign": "middle",
			"containerId": null,
			"originalText": "FF:FF:FF:FF:FF:FF = Broadcast (all devices)\n01:xx:xx:xx:xx:xx = Multicast\n00:00:00:00:00:00 = Unknown/unset\nLSB of first byte=1 = Multicast bit",
			"autoResize": true,
