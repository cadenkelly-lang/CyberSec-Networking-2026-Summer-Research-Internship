			"isDeleted": false,
			"boundElements": [],
			"updated": 1780695910379,
			"locked": false,
			"text": "IP: 10.0.0.20\nMAC: BB:BB:BB:22\nSubnet: 10.0.0.0/24\nGW: 10.0.0.1\nReceives frame.\nStrips eth header.\nPasses IP to OS.\nTCP/UDP to app.",
			"rawText": "IP: 10.0.0.20\nMAC: BB:BB:BB:22\nSubnet: 10.0.0.0/24\nGW: 10.0.0.1\nReceives frame.\nStrips eth header.\nPasses IP to OS.\nTCP/UDP to app.",
			"fontSize": 17,
			"fontFamily": 5,
			"textAlign": "center",
			"verticalAlign": "middle",
			"containerId": null,
			"originalText": "IP: 10.0.0.20\nMAC: BB:BB:BB:22\nSubnet: 10.0.0.0/24\nGW: 10.0.0.1\nReceives frame.\nStrips eth header.\nPasses IP to OS.\nTCP/UDP to app.",
