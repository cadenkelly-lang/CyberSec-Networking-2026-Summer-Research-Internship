			"link": null,
			"locked": false,
			"text": "IP: 192.168.1.20\nMAC: BB:BB:BB:22:22:22\nSubnet: /24\nMatches! Accept frame.",
			"rawText": "IP: 192.168.1.20\nMAC: BB:BB:BB:22:22:22\nSubnet: /24\nMatches! Accept frame.",
			"fontSize": 18,
			"fontFamily": 5,
