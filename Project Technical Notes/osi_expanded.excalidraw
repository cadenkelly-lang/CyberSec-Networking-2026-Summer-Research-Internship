		{
			"id": "cqBxnOqc",
			"type": "text",
			"x": -1010,
			"y": -182,
			"width": 341.07965087890625,
			"height": 450,
			"angle": 0,
			"strokeColor": "#1a1a1a",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 2,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"index": "f0LYTKQ",
			"roundness": null,
			"seed": 4616317,
			"version": 101,
			"versionNonce": 1776336664,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1780693999371,
			"link": null,
			"locked": false,
			"text": "ELECTRICAL (Copper/UTP/Coax):\n  Voltage high = 1, low = 0\n  NRZ, Manchester encoding\n\nOPTICAL (Fiber):\n  Light on = 1, off = 0\n  Immune to EMI\n  Very high speed and distance\n\nWIRELESS (802.11):\n  Radio frequency modulation\n  OFDM encoding\n  2.4 GHz / 5 GHz / 6 GHz bands\n\nKEY PRINCIPLE:\nAll signals represent BITS.\nDevices must agree on encoding\nto correctly interpret 1s and 0s.",
			"rawText": "ELECTRICAL (Copper/UTP/Coax):\n  Voltage high = 1, low = 0\n  NRZ, Manchester encoding\n\nOPTICAL (Fiber):\n  Light on = 1, off = 0\n  Immune to EMI\n  Very high speed and distance\n\nWIRELESS (802.11):\n  Radio frequency modulation\n  OFDM encoding\n  2.4 GHz / 5 GHz / 6 GHz bands\n\nKEY PRINCIPLE:\nAll signals represent BITS.\nDevices must agree on encoding\nto correctly interpret 1s and 0s.",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "ELECTRICAL (Copper/UTP/Coax):\n  Voltage high = 1, low = 0\n  NRZ, Manchester encoding\n\nOPTICAL (Fiber):\n  Light on = 1, off = 0\n  Immune to EMI\n  Very high speed and distance\n\nWIRELESS (802.11):\n  Radio frequency modulation\n  OFDM encoding\n  2.4 GHz / 5 GHz / 6 GHz bands\n\nKEY PRINCIPLE:\nAll signals represent BITS.\nDevices must agree on encoding\nto correctly interpret 1s and 0s.",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false
		},
