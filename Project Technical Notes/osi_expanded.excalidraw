			"versionNonce": 416056088,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1780694179510,
			"locked": false,
			"text": "HALF-DUPLEX: send OR receive (not simultaneously) - hub networks, CSMA/CD\nFULL-DUPLEX: send AND receive simultaneously - modern switches, no collisions\nAUTO-NEGOTIATION: devices agree on speed and duplex automatically",
			"rawText": "HALF-DUPLEX: send OR receive (not simultaneously) - hub networks, CSMA/CD\nFULL-DUPLEX: send AND receive simultaneously - modern switches, no collisions\nAUTO-NEGOTIATION: devices agree on speed and duplex automatically",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "HALF-DUPLEX: send OR receive (not simultaneously) - hub networks, CSMA/CD\nFULL-DUPLEX: send AND receive simultaneously - modern switches, no collisions\nAUTO-NEGOTIATION: devices agree on speed and duplex automatically",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"link": null
		},
